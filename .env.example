# H02 TCP binary
H02_TCP_ADDR=:7020
H02_TCP_HTTP_ADDR=:9092

# H02 UDP binary
H02_UDP_ADDR=:7021
H02_UDP_HTTP_ADDR=:9093

# Redis (both binaries)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_H02_DB=2
REDIS_POOL_SIZE=100

# Stream
STREAM_KEY=h02:telemetry
STREAM_MAX_LEN=100000
SESSION_PREFIX=h02:session:
ONLINE_Z_KEY=h02:online
CMD_CHANNEL=h02:cmd:

# Timing
AUTH_TIMEOUT=30s
HEARTBEAT_TIMEOUT=3m
WRITE_TIMEOUT=10s

# MySQL (set DB_ENABLED=true to require device approval)
DB_ENABLED=false
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_DATABASE=laravel
DB_DEVICE_TYPE_ID=3

# MySQL column overrides (rarely needed)
DB_DEVICES_TABLE=devices
DB_IMEI_COLUMN=imei
DB_APPROVED_COLUMN=is_approved
DB_STATUS_COLUMN=status
DB_TYPE_ID_COLUMN=device_type_id
DB_NAME_COLUMN=name
DB_NOTES_COLUMN=notes
DB_CREATED_AT_COLUMN=created_at
DB_UPDATED_AT_COLUMN=updated_at

# App
APP_DEBUG=false
SERVER_ID=
